# All optional — sensible defaults are baked into src/config.ts.

# PORT=4000
# WORKSPACES_ROOT=./workspaces
# VERSION_HISTORY_ROOT=./version-history
# GIT_PATH=git
# TECTONIC_PATH=tectonic
# MAX_SOURCE_BYTES=300000
# COMPILE_TIMEOUT_MS=60000
# MAX_CONCURRENT_COMPILES=4
# CORS_ORIGIN=*

# DATABASE_URL=postgres://postgres@localhost:5433/mini_overleaf
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=mini-overleaf
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# MAX_UPLOAD_BYTES=10485760
# PERSIST_DEBOUNCE_MS=2000

# Google sign-in (optional — omit entirely to leave it disabled). Create a
# Web application OAuth Client ID at https://console.cloud.google.com/apis/credentials
# and use the same value here and in frontend/.env's VITE_GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# SESSION_TTL_DAYS=30
